{
  "expo": {
    "name": "3Play",
    "slug": "3play",
    "version": "1.0.0",
    "orientation": "portrait",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0B0B0D"
    },
    "updates": {
      "enabled": true,
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.threeplay.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0B0B0D"
      },
      "package": "com.threeplay.app"
    },
    "web": {
      "favicon": "../public/favicons/favicon-32x32.png"
    }
  }
}
